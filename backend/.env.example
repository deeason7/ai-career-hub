# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_SERVER=db
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=aicareerhub
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_jwt_key_change_in_prod_at_least_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── AI Backend ───────────────────────────────────────────────────────────────
# Option A (Local / Docker): Ollama — default, no key needed
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Option B (Cloud / Free): Groq — takes priority over Ollama when set
# Get your FREE key at: https://console.groq.com (6000 req/day free)
# Leave blank to use Ollama instead.
GROQ_API_KEY=
GROQ_LLM_MODEL=llama-3.1-8b-instant

# ─── Observability ────────────────────────────────────────────────────────────
# Optional: Sentry error tracking — leave blank to disable
# Free DSN at: https://sentry.io (10k errors/month free)
SENTRY_DSN=

# ─── Runtime Flags ────────────────────────────────────────────────────────────
# Set to true on Render to hide /docs and /redoc in production
PRODUCTION=false

# Set to true in CI/test environments — disables rate limiting
TESTING=false

# ─── Database Pool (optional tuning for Supabase Session mode) ────────────────
# Supabase Transaction mode (port 6543) allows higher pool sizes
# Session mode (port 5432) limits to ~3–5 connections on free tier
SQLALCHEMY_POOL_SIZE=2
SQLALCHEMY_MAX_OVERFLOW=3
